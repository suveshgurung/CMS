  <property name="styleSheet">
   <string notr="true">/* Dark Mode Style */
QWidget[theme=&quot;dark&quot;] {
    background-color: rgb(45, 45, 45);
    color: white;
}

QPushButton[theme=&quot;dark&quot;] {
    background-color: rgb(70, 70, 70);
    border: 2px solid rgb(90, 90, 90);
    color: white;
}

QPushButton[theme=&quot;dark&quot;]:hover {
    background-color: rgb(100, 100, 100);
}

/* Light Mode Style (Default) */
QWidget[theme=&quot;light&quot;] {
    background-color: white;
    color: black;
}

QPushButton[theme=&quot;light&quot;] {
    background-color: rgb(0, 122, 0);
    border: 2px solid rgb(0, 102, 0);
    color: white;
}

QPushButton[theme=&quot;light&quot;]:hover {
    background-color: rgb(255, 255, 255);
    color: black;
    border: 2px solid rgb(0, 122, 0);
}

</string>
